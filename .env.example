# ============================================================
# Zoe CLI - Environment Variables (DEVELOPMENT ONLY)
# ============================================================
# 
# This file is for DEVELOPMENT purposes only.
# 
# For production use, Zoe reads configuration from:
#   - .insforge/project.json (InsForge configuration)
#   - .zoe/config.json (Zoe session and preferences)
#
# Users do NOT need to configure these variables.
# ============================================================

# InsForge Configuration (for development)
# Get these values by running: npx @insforge/cli project info
INSFORGE_URL=https://api.insforge.dev
INSFORGE_ANON_KEY=your-anon-key-here
INSFORGE_PROJECT_ID=your-project-id-here

# OpenRouter API Key (only for development/testing)
# In production, this is managed by InsForge AI Gateway
OPENROUTER_API_KEY=your-openrouter-key-here

# Default model (optional)
DEFAULT_MODEL=deepseek/deepseek-v4-pro

# Zoe Configuration (optional)
ZOE_MAX_STEPS=100
ZOE_MAX_COST=10
ZOE_AUTO_SCAN=true
